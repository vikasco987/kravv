{
  "expo": {
    "name": "kravy",
    "slug": "kravy",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/kravlogo.png",
    "scheme": "kravy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vikas9095.kravy",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 8,
      "adaptiveIcon": {
        "backgroundColor": "#1e3a8a",
        "foregroundImage": "./assets/images/kravlogo.png",
        "backgroundImage": "./assets/images/kravlogo.png",
        "monochromeImage": "./assets/images/kravlogo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.vikas9095.kravy",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/kravlogo.png"
    },
    "plugins": [
      "@react-native-voice/voice",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/kravlogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-audio",
      "expo-video",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "cameraPermission": "The app accesses your camera to let you take item photos.",
          "photosPermission": "The app accesses your photos to let you set item images."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true,
            "queries": [
              "android.speech.RecognitionService"
            ],
            "unstable_interopModules": [
              "RCTVoice"
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "newArchEnabled": true
    },
    "extra": {
      "router": {},
      "clerkPublishableKey": "pk_test_bXVzaWNhbC1oZXJyaW5nLTgwLmNsZXJrLmFjY291bnRzLmRldiQ",
      "eas": {
        "projectId": "056e27e8-d1c0-4d4d-8107-06eeae9b91af"
      }
    },
    "owner": "vikash111s-organization"
  }
}
